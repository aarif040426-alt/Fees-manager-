{
  "entities": {
    "Teacher": {
      "title": "Teacher",
      "description": "A tutor using the system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "mobile": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "teacher"] },
        "plan": { "type": "string", "enum": ["Free", "Pro", "Enterprise"] },
        "planStartDate": { "type": "string", "format": "date-time" },
        "theme": { "type": "string", "enum": ["light", "dark"] },
        "photoUrl": { "type": "string" },
        "tuitionName": { "type": "string", "description": "Name of the tuition or institute" },
        "notifications": {
          "type": "object",
          "properties": {
            "email": { "type": "boolean" },
            "whatsapp": { "type": "boolean" },
            "paymentReminders": { "type": "boolean" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "plan", "theme"]
    },
    "Student": {
      "title": "Student",
      "description": "A student managed by a teacher.",
      "type": "object",
      "properties": {
        "teacherId": { "type": "string", "description": "UID of the teacher" },
        "name": { "type": "string" },
        "parentName": { "type": "string" },
        "mobile": { "type": "string" },
        "board": { "type": "string", "enum": ["SSC", "ICSE", "CBSE", "Other"] },
        "standard": { "type": "string" },
        "feeAmount": { "type": "number" },
        "joiningDate": { "type": "string", "format": "date" },
        "photoUrl": { "type": "string" }
      },
      "required": ["teacherId", "name", "feeAmount"]
    },
    "Payment": {
      "title": "Payment",
      "description": "A fee payment record for a student for a specific month.",
      "type": "object",
      "properties": {
        "teacherId": { "type": "string" },
        "studentId": { "type": "string" },
        "month": { "type": "string", "description": "YYYY-MM format" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["Paid", "Pending", "Partial"] },
        "method": { "type": "string", "enum": ["Cash", "Online"] },
        "paidAt": { "type": "string", "format": "date-time" }
      },
      "required": ["teacherId", "studentId", "month", "status"]
    },
    "PlanRequest": {
      "title": "PlanRequest",
      "description": "A request for a plan upgrade.",
      "type": "object",
      "properties": {
        "teacherId": { "type": "string" },
        "teacherName": { "type": "string" },
        "teacherEmail": { "type": "string" },
        "currentPlan": { "type": "string", "enum": ["Free", "Pro", "Enterprise"] },
        "requestedPlan": { "type": "string", "enum": ["Free", "Pro", "Enterprise"] },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["teacherId", "requestedPlan", "status", "createdAt"]
    },
    "TeacherStatus": {
      "title": "TeacherStatus",
      "description": "Publicly accessible teacher approval status.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "status"]
    }
  },
  "firestore": {
    "/teachers/{teacherId}": {
      "schema": "Teacher",
      "description": "Teacher profiles"
    },
    "/teacher_status/{teacherId}": {
      "schema": "TeacherStatus",
      "description": "Public teacher status for unauthenticated checks"
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Student records"
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Payment history"
    },
    "/planRequests/{requestId}": {
      "schema": "PlanRequest",
      "description": "Requests for plan upgrades"
    }
  }
}
